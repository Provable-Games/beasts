############################################################
# Copy this file to .env and fill in ALL values below.
# The deploy script will fail if any are missing.
############################################################

# Starknet account details (required)
STARKNET_ACCOUNT="<starkli-account-address>"
STARKNET_PRIVATE_KEY="<starkli-private-key-hex>"

# Network RPC (required)
# e.g., Sepolia: https://api.cartridge.gg/x/starknet/sepolia
#        Mainnet: https://<your-mainnet-rpc>
RPC_URL="<rpc-url>"

# NFT constructor params (required)
NAME="<collection-name>"
SYMBOL="<collection-symbol>"

# Owner and royalty configuration (required)
OWNER="<owner-address>"
ROYALTY_RECEIVER="<royalty-receiver-address>"
ROYALTY_FRACTION="<u128-fraction>" # e.g., 500 = 5% (denominator 10,000)

# Terminal behavior (optional)
# UNIX timestamp in seconds after which token_uri should be disabled.
# Set to 0 to disable terminal behavior and keep token_uri active indefinitely.
TERMINAL_TIMESTAMP="0"

# External systems integration (optional)
# Set to a contract address to enable Death Mountain integration; use 0 to disable
DEATH_MOUNTAIN_ADDRESS="0"

############################################################
# Tiddy Mun sncast deploy settings (scripts/deploy_tiddy_mun.sh)
############################################################

# sncast profile in snfoundry.toml. Defaults to "default" when omitted.
SNCAST_PROFILE="default"

# sncast account configuration. These are consumed by snfoundry.toml.
SNCAST_ACCOUNT="<sncast-account-name>"
SNCAST_ACCOUNTS_FILE="~/.starknet_accounts/starknet_open_zeppelin_accounts.json"
SEPOLIA_RPC_URL="<sepolia-rpc-url>"
MAINNET_RPC_URL="<mainnet-rpc-url>"

# Tiddy Mun minter configuration.
MINTER_ADDRESS="<minter-address>"

# Notes:
# - Do NOT commit your real STARKNET_PRIVATE_KEY. This file is provided as an example.
# - Copy to .env and fill in all required variables before running deploy scripts.
