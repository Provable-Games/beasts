############################################################
# Copy this file to .env and fill in ALL values below.
# The deploy script will fail if any are missing.
############################################################

# Starknet account details (required)
STARKNET_ACCOUNT="<starkli-account-address>"
STARKNET_PRIVATE_KEY="<starkli-private-key-hex>"

# Network RPC (required)
# e.g., Sepolia: https://api.cartridge.gg/x/starknet/sepolia
#        Mainnet: https://<your-mainnet-rpc>
RPC_URL="<rpc-url>"

# NFT constructor params (required)
NAME="<collection-name>"
SYMBOL="<collection-symbol>"

# Owner and royalty configuration (required)
OWNER="<owner-address>"
ROYALTY_RECEIVER="<royalty-receiver-address>"
ROYALTY_FRACTION="<u128-fraction>" # e.g., 500 = 5% (denominator 10,000)

# Notes:
# - Do NOT commit your real STARKNET_PRIVATE_KEY. This file is provided as an example.
# - Copy to .env and fill in all required variables before running scripts/deploy.sh.
