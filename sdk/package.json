{
  "name": "@lootsurvivor/beast-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Beast NFT data lookups and local SVG rendering",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "extract-images": "node scripts/extract-beast-images.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
